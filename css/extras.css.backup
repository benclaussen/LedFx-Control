:root {
    --btn-black: #000;
    --btn-white: #fff;
    --btn-red: #ff0000;
    --btn-orange: #ff8c00;
    --btn-yellow: #ffff00;
    --btn-green: #00FF00;
    --btn-blue: #0000FF;
    --btn-purple: #640080;
    --btn-pink: #ff00ff;
}

.alert1 {
    max-width: 500px;
}

.flash-button {
    width: 100%;
    padding: 10px 20px;
    margin-bottom: 5px;
    border-radius: 5px;
    border-color: black;
    line-height: 30px;
    transition: background-color 0.3s;
}

.flash-button-black {
    color: var(--btn-white);
    background-color: var(--btn-black);
    border: 2px solid var(--btn-white);
}

.flash-button-white {
    color: var(--btn-black);
    background-color: var(--btn-white);
    border: 2px solid #AAAAAA;
}

.flash-button-red {
    color: var(--btn-white);
    background-color: var(--btn-red);
    border: 2px solid var(--btn-red);
}

.flash-button-orange {
    color: var(--btn-white);
    background-color: var(--btn-orange);
    border: 2px solid var(--btn-orange);
}

.flash-button-yellow {
    color: var(--btn-black);
    background-color: var(--btn-yellow);
    border: 2px solid var(--btn-yellow);
}

.flash-button-green {
    color: var(--btn-white);
    background-color: var(--btn-green);
    border: 2px solid var(--btn-green);
}

.flash-button-blue {
    color: var(--btn-white);
    background-color: var(--btn-blue);
    border: 2px solid var(--btn-blue);
}

.flash-button-purple {
    color: var(--btn-white);
    background-color: var(--btn-purple);
    border: 2px solid var(--btn-purple);
}

.flash-button-pink {
    color: var(--btn-white);
    background-color: var(--btn-pink);
    border: 2px solid var(--btn-pink);
}

.flash-button:hover {
    filter: brightness(85%);
    border-color: white;
}

.flash-button:active {
    filter: brightness(70%);
}

